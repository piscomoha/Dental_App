APP_NAME="Dental App"
APP_ENV=local
APP_KEY=base64:YOUR_KEY_HERE_CHANGE_THIS
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ============================================
# MAINTENANCE & WORKERS
# ============================================
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# ============================================
# ENCRYPTION & HASHING
# ============================================
BCRYPT_ROUNDS=12

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE (MySQL/MariaDB)
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dental_db
DB_USERNAME=dental_user
DB_PASSWORD=SECURE_PASSWORD_HERE

# ============================================
# DATABASE SECURITY
# ============================================
DB_QUERY_LOGGING=false

# ============================================
# SESSION & COOKIES
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIES=false
SESSION_SAME_SITE=Lax

# ============================================
# BROADCASTING
# ============================================
BROADCAST_CONNECTION=log

# ============================================
# FILE SYSTEM
# ============================================
FILESYSTEM_DISK=local

# ============================================
# QUEUE
# ============================================
QUEUE_CONNECTION=database

# ============================================
# CACHING
# ============================================
CACHE_STORE=database
CACHE_PREFIX=dental_cache_

# ============================================
# MEMCACHED
# ============================================
MEMCACHED_HOST=127.0.0.1

# ============================================
# REDIS
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# MAIL
# ============================================
MAIL_MAILER=log
MAIL_HOST=mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@dentalapp.local
MAIL_FROM_NAME="Dental App"

# ============================================
# AWS (Optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# FRONTEND VITE CONFIG
# ============================================
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000/api

# ============================================
# CORS & API SECURITY
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# RATE LIMITING
# ============================================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT=60
API_RATE_WINDOW=1

# ============================================
# REQUEST LOGGING
# ============================================
API_REQUEST_LOGGING=false

# ============================================
# PRODUCTION SETTINGS
# ============================================
# Uncomment and adjust when deploying to production:
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIES=true
# SESSION_SAME_SITE=Strict
# DB_QUERY_LOGGING=false
# API_REQUEST_LOGGING=false
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
